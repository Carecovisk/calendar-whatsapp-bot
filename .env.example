# Cron schedule (default: 7:00 AM every day)
CRON_SCHEDULE=0 7 * * *

# Timezone for the container and cron
TZ=America/Sao_Paulo

# Google Calendar
CALENDAR_ID=your-calendar-id@gmail.com
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# Recipients: comma-separated phone numbers with country code (no + or spaces)
# Example: 5511999999999,5521888888888
RECIPIENTS=5511999999999

# WhatsApp session folder (persisted via Docker volume)
WA_AUTH_FOLDER=./auth_info

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
